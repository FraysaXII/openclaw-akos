# ci-baseline.yml.tmpl
#
# AKOS canonical GitHub Actions workflow template (Initiative 68 P5; D-IH-68-D).
#
# Operator-applied via `scripts/bless_external_repo.py --with ci-baseline`
# (extension lands at I68 P5 PAUSE POINT #3 — canonical CSV gate).
#
# Per-class enforcement:
#   class=platform      → runs every job below (lint + typecheck + unit-test +
#                         playwright-smoke + visual-regression + lighthouse +
#                         brand-jargon + brand-voice + sentry-release-format
#                         + sentry-skip-on-preview + build-time-target).
#   class=reference     → same as platform (boilerplate IS the brand surface;
#                         every check at strictest setting).
#   class=internal      → only lint + typecheck + unit-test (no rendered
#                         surface; visual + observability skipped).
#   class=client-delivery → TBD when first such repo blesses.
#
# Per-repo opt-out is encoded in REPOSITORY_REGISTRY.csv ci_baseline_optouts
# JSON-array column (lands in I68 P5 PAUSE POINT #3); see
#   docs/references/hlk/v3.0/Admin/O5-1/Tech/System Owner/SOP-CICD_BASELINE_001.md §7.
#
# Drift detection: every consumer-repo `.github/workflows/ci-baseline.yml`
# mirrors this template; sha256 stamped in REPOSITORY_REGISTRY.csv at bless
# time and re-checked nightly via scripts/check_external_repo_ci_posture.py.
#
# When this template changes:
#   1. Bump SOP-CICD_BASELINE_001.md frontmatter `version` (semver).
#   2. Open per-repo PRs to update each consumer-repo's mirror.
#   3. Update scripts/check_external_repo_ci_posture.py expected sha256.
#   4. Per akos-docs-config-sync.mdc the doc-sync row triggers automatically.
#
# REQUIRED REPO SECRETS (operator sets these in GitHub repo settings → Actions):
#   VERCEL_AUTOMATION_BYPASS_SECRET   (for class=platform/reference Vercel repos)
#   ARGOS_TOKEN                       (for visual-regression jobs; per D-IH-68-A)
#   SENTRY_AUTH_TOKEN                 (for source-map upload on production builds)

name: ci-baseline

on:
  pull_request:
    branches: [main, master]
  push:
    branches: [main, master]

env:
  # Replaced at bless-time with the consumer repo's slug from REPOSITORY_REGISTRY.csv.
  REPO_SLUG: '<REPO_SLUG_PLACEHOLDER>'
  # Node version pinned per consumer repo's package.json engines.node; matrix expansion
  # is added by --with ci-baseline when the repo specifies a multi-version range.
  NODE_VERSION: '20'

jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: npm
      - run: npm ci
      - run: npm run lint

  typecheck:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: npm
      - run: npm ci
      - run: npx tsc --noEmit

  unit-test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: npm
      - run: npm ci
      - run: npm test

  playwright-smoke:
    # Skipped via `if: !contains(...)` when the consumer repo's
    # ci_baseline_optouts JSON includes 'playwright-smoke'. The bless flow
    # encodes opt-outs at workflow-stamp time as `if: false` for clarity.
    runs-on: ubuntu-latest
    needs: [lint, typecheck, unit-test]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: npm
      - run: npm ci
      - run: npx playwright install --with-deps
      - name: Wait for Vercel preview URL
        if: github.event_name == 'pull_request'
        run: |
          # Operator-managed: typically a poll loop on the deploys API. The bless
          # flow stamps in the canonical poll script when --with ci-baseline runs;
          # the placeholder here keeps the template valid for syntax-checking.
          echo "TODO: poll Vercel deploys API for the PR head SHA's preview URL"
          echo "PREVIEW_URL=http://localhost:3000" >> $GITHUB_ENV
      - run: npx playwright test
        env:
          PREVIEW_URL: ${{ env.PREVIEW_URL }}
          VERCEL_AUTOMATION_BYPASS_SECRET: ${{ secrets.VERCEL_AUTOMATION_BYPASS_SECRET }}

  visual-regression:
    # Argos PR-comment integration per D-IH-68-A. PR-from-fork hardening per
    # R-IH-68-12 mitigation: pull_request_target with explicit fork refusal
    # unless PR carries `vetted-by-owner` label.
    runs-on: ubuntu-latest
    needs: [playwright-smoke]
    if: |
      github.event_name == 'pull_request' &&
      (
        github.event.pull_request.head.repo.fork == false ||
        contains(github.event.pull_request.labels.*.name, 'vetted-by-owner')
      )
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: npm
      - run: npm ci
      - run: npx playwright install --with-deps
      - run: npx playwright test --project=desktop --project=iphone-se --project=ipad
      - run: npx @argos-ci/cli upload --token=${{ secrets.ARGOS_TOKEN }} screenshots/

  brand-jargon:
    # Per SOP-CICD_BASELINE_001 §3: class=reference (boilerplate) carries the
    # full brand-jargon set; class=platform that ships public prose carries it
    # too; class=internal skips. Bless flow stamps `if: false` when opted-out.
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      # The validator currently lives in AKOS; consumer repos invoke it via the
      # blessed CLI shim that wraps it. Until I69 ships @holistika/cicd-baseline-cli
      # as an npm package, repos clone the AKOS validator at workflow time:
      - run: |
          git clone --depth 1 https://github.com/FraysaXII/openclaw-akos /tmp/akos
          cd /tmp/akos
          py -m pip install -r requirements.txt
          py scripts/validate_brand_jargon.py

  sentry-release-format:
    # Per D-IH-68-I: every Holistika consumer-repo Sentry init carries the
    # `<repo_slug>@<sha_short>` release format. Validator scans sentry config files.
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - run: |
          git clone --depth 1 https://github.com/FraysaXII/openclaw-akos /tmp/akos
          cd /tmp/akos
          py -m pip install -r requirements.txt
          AKOS_SENTRY_RELEASE_SCAN_CONSUMERS=1 py scripts/validate_sentry_release_format.py

  build-time-target:
    # Asserts preview build is under build_time_target_seconds from
    # REPOSITORY_REGISTRY.csv (column lands in I68 P5 PAUSE POINT #3). Until
    # the column lands the job is informational; bless flow stamps the
    # numerical target at adoption time.
    runs-on: ubuntu-latest
    needs: [lint, typecheck, unit-test]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: npm
      - name: Measure build time
        id: build_time
        run: |
          start=$(date +%s)
          npm ci
          npm run build
          end=$(date +%s)
          delta=$((end - start))
          echo "delta=$delta" >> $GITHUB_OUTPUT
          echo "Build took ${delta}s"
      - name: Assert build under target
        # <BUILD_TIME_TARGET_SECONDS_PLACEHOLDER> is replaced at bless-time
        # from REPOSITORY_REGISTRY.csv build_time_target_seconds.
        run: |
          if [ ${{ steps.build_time.outputs.delta }} -gt <BUILD_TIME_TARGET_SECONDS_PLACEHOLDER> ]; then
            echo "::warning::Build took ${{ steps.build_time.outputs.delta }}s, exceeds target <BUILD_TIME_TARGET_SECONDS_PLACEHOLDER>s"
            # Soft warning until I68 P6 build-time optimisation sweep makes targets reliably hit.
            # Flips to `exit 1` in I68 P8 closure once per-repo targets stabilise.
          fi
