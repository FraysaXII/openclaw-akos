# Credentials and secrets
.env
*.pem
*.key
credentials.json
openclaw.json

# Environment profiles with real secrets (keep .env.example templates)
config/environments/*.env
!config/environments/*.env.example
config/eval/*.env
!config/eval/*.env.example

# API keys and live MCP config (user-specific paths)
.mcporter/
config/mcporter.json

# OS artifacts
.DS_Store
Thumbs.db
Desktop.ini

# Editor and IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
logs/
*.log

# Node.js (for MCP server tooling)
node_modules/
package-lock.json

# Docker
.docker/

# Splunk forwarder data
splunkforwarder/

# Python
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
dist/
build/

# Assembled prompts (generated by scripts/assemble-prompts.py)
prompts/assembled/

# Temporary files
tmp/
temp/
*.tmp
