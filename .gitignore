.cursor/plans/

# Raw release-gate / validator stdout dumps under planning reports
# (transient; per-run timestamped; canonical evidence is the structured
# reports/p<N>-*.md or reports/uat-*.md). Regenerable via re-running the
# corresponding validator or `py scripts/release-gate.py`.
docs/wip/planning/**/reports/*-raw-*.txt
docs/wip/planning/**/reports/release-gate-raw-*.txt

# Obsidian local state under HLK vault (per-operator; not canonical)
docs/references/hlk/v3.0/.obsidian/

# Operator-managed Google Sheets binaries (canonical SSOT is the CSV)
*.gsheet

# Obsidian / Cursor canvas scratch files (per-operator; not canonical)
*.canvas

