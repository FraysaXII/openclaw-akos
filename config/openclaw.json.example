{
  "gateway": {
    "host": "127.0.0.1",
    "port": 18789
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/qwen3:8b"
      },
      "thinkingDefault": "off",
      "verboseDefault": "on",
      "workspace": "~/.openclaw/workspace",
      "memorySearch": {
        "provider": "local",
        "model": "nomic-embed-text:latest"
      }
    },
    "list": [
      {
        "id": "architect",
        "name": "Architect (Read-Only Planner)",
        "workspace": "~/.openclaw/workspace-architect",
        "identity": {
          "name": "Architect",
          "theme": "read-only strategic planner in the AKOS dual-agent paradigm",
          "emoji": "📐"
        }
      },
      {
        "id": "executor",
        "name": "Executor (Read-Write Builder)",
        "workspace": "~/.openclaw/workspace-executor",
        "identity": {
          "name": "Executor",
          "theme": "fast read-write builder in the AKOS dual-agent paradigm",
          "emoji": "🔧"
        }
      }
    ]
  },
  "bindings": [
    {
      "match": { "channel": "telegram" },
      "agentId": "architect"
    },
    {
      "match": { "channel": "slack", "teamId": "YOUR_TEAM_ID" },
      "agentId": "executor"
    }
  ],
  "logging": {
    "format": "json",
    "output_directory": "/opt/openclaw/logs/"
  },
  "permissions": "$import:permissions.json"
}
