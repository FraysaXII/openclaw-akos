{
  "gateway": {
    "host": "127.0.0.1",
    "port": 18789
  },
  "models": {
    "providers": {
      "ollama-local": {
        "baseUrl": "http://127.0.0.1:11434/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3:8b",
            "name": "Qwen3 8B",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 16384,
            "maxTokens": 16384,
            "cost": { "input": 0, "output": 0 }
          },
          {
            "id": "llama3.1:8b",
            "name": "Llama 3.1 8B",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 16384,
            "maxTokens": 16384,
            "cost": { "input": 0, "output": 0 }
          },
          {
            "id": "nomic-embed-text",
            "name": "Nomic Embed Text",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 8192,
            "maxTokens": 8192,
            "cost": { "input": 0, "output": 0 }
          }
        ]
      },
      "ollama-gpu": {
        "baseUrl": "${OLLAMA_GPU_URL}",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3:32b",
            "name": "Qwen3 32B",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 32768,
            "maxTokens": 16384,
            "cost": { "input": 0, "output": 0 }
          }
        ]
      },
      "openai": {
        "apiKey": { "source": "env", "id": "OPENAI_API_KEY" },
        "models": []
      },
      "anthropic": {
        "apiKey": { "source": "env", "id": "ANTHROPIC_API_KEY" },
        "models": []
      },
      "vllm-runpod": {
        "baseUrl": "${VLLM_RUNPOD_URL}",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-r1-70b",
            "name": "DeepSeek R1 70B",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 16384,
            "cost": { "input": 0, "output": 0 }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/qwen3:8b"
      },
      "thinkingDefault": "off",
      "verboseDefault": "on",
      "workspace": "~/.openclaw/workspace",
      "memorySearch": {
        "provider": "local",
        "model": "nomic-embed-text:latest"
      }
    },
    "list": [
      {
        "id": "architect",
        "name": "Architect (Read-Only Planner)",
        "workspace": "~/.openclaw/workspace-architect",
        "identity": {
          "name": "Architect",
          "theme": "read-only strategic planner in the AKOS dual-agent paradigm",
          "emoji": "📐"
        }
      },
      {
        "id": "executor",
        "name": "Executor (Read-Write Builder)",
        "workspace": "~/.openclaw/workspace-executor",
        "identity": {
          "name": "Executor",
          "theme": "fast read-write builder in the AKOS dual-agent paradigm",
          "emoji": "🔧"
        }
      }
    ]
  },
  "bindings": [
    {
      "match": { "channel": "telegram" },
      "agentId": "architect"
    },
    {
      "match": { "channel": "slack", "teamId": "YOUR_TEAM_ID" },
      "agentId": "executor"
    }
  ],
  "logging": {
    "format": "json",
    "output_directory": "/opt/openclaw/logs/"
  },
  "permissions": "$import:permissions.json"
}
