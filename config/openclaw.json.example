{
  "gateway": {
    "host": "127.0.0.1",
    "port": 18789
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434",
        "apiKey": "${OLLAMA_API_KEY}",
        "api": "ollama",
        "models": [
          {
            "id": "qwen3:8b",
            "name": "Qwen3 8B",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 16384,
            "maxTokens": 16384,
            "cost": { "input": 0, "output": 0 }
          },
          {
            "id": "llama3.1:8b",
            "name": "Llama 3.1 8B",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 16384,
            "maxTokens": 16384,
            "cost": { "input": 0, "output": 0 }
          },
          {
            "id": "deepseek-r1:14b",
            "name": "DeepSeek R1 14B",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 32768,
            "maxTokens": 16384,
            "cost": { "input": 0, "output": 0 }
          },
          {
            "id": "nomic-embed-text",
            "name": "Nomic Embed Text",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 8192,
            "maxTokens": 8192,
            "cost": { "input": 0, "output": 0 }
          }
        ]
      },
      "ollama-gpu": {
        "baseUrl": "${OLLAMA_GPU_URL}",
        "api": "ollama",
        "models": [
          {
            "id": "qwen3:32b",
            "name": "Qwen3 32B",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 32768,
            "maxTokens": 16384,
            "cost": { "input": 0, "output": 0 }
          }
        ]
      },
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "models": []
      },
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "apiKey": "${ANTHROPIC_API_KEY}",
        "models": []
      },
      "vllm-runpod": {
        "baseUrl": "${VLLM_RUNPOD_URL}",
        "apiKey": "${RUNPOD_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-r1-70b",
            "name": "DeepSeek R1 70B",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 16384,
            "cost": { "input": 0, "output": 0 }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/qwen3:8b",
        "fallbacks": ["ollama/deepseek-r1:14b", "ollama/qwen3:8b"]
      },
      "thinkingDefault": "off",
      "verboseDefault": "on",
      "workspace": "~/.openclaw/workspace",
      "memorySearch": {
        "provider": "local",
        "model": "nomic-embed-text:latest"
      }
    },
    "list": [
      {
        "id": "orchestrator",
        "name": "Orchestrator (Multi-Agent Coordinator)",
        "workspace": "~/.openclaw/workspace-orchestrator",
        "identity": {
          "name": "Orchestrator",
          "theme": "multi-agent coordinator that decomposes tasks and delegates",
          "emoji": "🎯"
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "web_search",
            "web_fetch",
            "memory_search",
            "memory_get",
            "sequential_thinking",
            "finance_search",
            "finance_quote",
            "finance_sentiment",
            "hlk_role",
            "hlk_role_chain",
            "hlk_area",
            "hlk_process",
            "hlk_process_tree",
            "hlk_projects",
            "hlk_gaps",
            "hlk_search"
          ],
          "deny": ["write", "edit", "apply_patch", "exec", "browser"]
        }
      },
      {
        "id": "architect",
        "name": "Architect (Read-Only Planner)",
        "workspace": "~/.openclaw/workspace-architect",
        "identity": {
          "name": "Architect",
          "theme": "read-only strategic planner in the AKOS multi-agent paradigm",
          "emoji": "📐"
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "web_search",
            "web_fetch",
            "memory_search",
            "memory_get",
            "browser",
            "sequential_thinking",
            "finance_search",
            "finance_quote",
            "finance_sentiment",
            "hlk_role",
            "hlk_role_chain",
            "hlk_area",
            "hlk_process",
            "hlk_process_tree",
            "hlk_projects",
            "hlk_gaps",
            "hlk_search"
          ],
          "deny": ["write", "edit", "apply_patch", "exec"]
        }
      },
      {
        "id": "executor",
        "name": "Executor (Read-Write Builder)",
        "workspace": "~/.openclaw/workspace-executor",
        "identity": {
          "name": "Executor",
          "theme": "fast read-write builder in the AKOS multi-agent paradigm",
          "emoji": "🔧"
        },
        "tools": {
          "profile": "coding",
          "alsoAllow": [
            "finance_search",
            "finance_quote",
            "finance_sentiment",
            "hlk_role",
            "hlk_role_chain",
            "hlk_area",
            "hlk_process",
            "hlk_process_tree",
            "hlk_projects",
            "hlk_gaps",
            "hlk_search"
          ]
        }
      },
      {
        "id": "verifier",
        "name": "Verifier (Quality Gate)",
        "workspace": "~/.openclaw/workspace-verifier",
        "identity": {
          "name": "Verifier",
          "theme": "quality gate that validates executor output via tests and linting",
          "emoji": "✅"
        },
        "tools": {
          "profile": "coding",
          "alsoAllow": [
            "finance_search",
            "finance_quote",
            "finance_sentiment",
            "hlk_role",
            "hlk_role_chain",
            "hlk_area",
            "hlk_process",
            "hlk_process_tree",
            "hlk_projects",
            "hlk_gaps",
            "hlk_search"
          ],
          "deny": ["write", "edit", "apply_patch"]
        }
      },
      {
        "id": "madeira",
        "name": "Madeira (HLK Operations Assistant)",
        "workspace": "~/.openclaw/workspace-madeira",
        "identity": {
          "name": "Madeira",
          "theme": "user-facing operational assistant for the Holistika knowledge vault",
          "emoji": "🌊"
        },
        "tools": {
          "profile": "coding",
          "alsoAllow": [
            "finance_search",
            "finance_quote",
            "finance_sentiment",
            "hlk_role",
            "hlk_role_chain",
            "hlk_area",
            "hlk_process",
            "hlk_process_tree",
            "hlk_projects",
            "hlk_gaps",
            "hlk_search"
          ],
          "deny": ["write", "edit", "apply_patch", "exec"]
        }
      }
    ]
  },
  "tools": {
    "profile": "coding",
    "exec": {
      "security": "allowlist",
      "ask": "on-miss",
      "host": "sandbox"
    },
    "loopDetection": {
      "enabled": true,
      "warningThreshold": 10,
      "criticalThreshold": 20,
      "globalCircuitBreakerThreshold": 30
    },
    "agentToAgent": {
      "enabled": true,
      "allow": ["orchestrator", "architect", "executor", "verifier", "madeira"]
    }
  },
  "session": {
    "scope": "per-sender",
    "reset": {"mode": "idle", "idleMinutes": 60},
    "agentToAgent": {"maxPingPongTurns": 3},
    "typingMode": "thinking"
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "defaultProfile": "akos",
    "ssrfPolicy": {"dangerouslyAllowPrivateNetwork": false}
  },
  "messages": {
    "statusReactions": {"enabled": true},
    "suppressToolErrors": false
  },
  "bindings": [
    {
      "match": { "channel": "telegram" },
      "agentId": "architect"
    },
    {
      "match": { "channel": "slack", "teamId": "YOUR_TEAM_ID" },
      "agentId": "executor"
    }
  ],
  "logging": {
    "_note": "output_directory is Linux production path. On Windows dev, OpenCLAW writes to %TEMP%/openclaw/ by default.",
    "format": "json",
    "output_directory": "/opt/openclaw/logs/"
  },
  "permissions": "$import:permissions.json"
}
