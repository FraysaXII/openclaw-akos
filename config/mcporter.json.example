{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {
        "DISABLE_THOUGHT_LOGGING": "false"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--output-dir",
        "/opt/openclaw/workspace/exports"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "_note": "Extend for search_commits, show_commit (historical context). Set GITHUB_TOKEN to enable."
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/opt/openclaw/workspace"
      ]
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ]
    },
    "lsp": {
      "command": "npx",
      "args": [
        "-y",
        "@akos/mcp-lsp-server"
      ],
      "env": {
        "LSP_LANGUAGES": "python,typescript"
      },
      "_note": "Phase 4: LSP code intelligence. Provides get_diagnostics, go_to_definition, find_references, get_type_signature."
    },
    "code-search": {
      "command": "npx",
      "args": [
        "-y",
        "@akos/mcp-code-search"
      ],
      "_note": "Phase 4: Semantic code search via ripgrep + tree-sitter. Provides search_code(query, scope)."
    },
    "akos": {
      "command": "python",
      "args": ["scripts/mcp_akos_server.py"],
      "env": {
        "AKOS_API_URL": "http://127.0.0.1:8420"
      },
      "_note": "Custom AKOS MCP. Exposes akos_health, akos_agents, akos_status. Requires: pip install mcp httpx. Cwd must be AKOS repo root."
    },
    "finance": {
      "command": "python",
      "args": ["scripts/finance_mcp_server.py"],
      "env": {
        "ALPHA_VANTAGE_KEY": "${ALPHA_VANTAGE_KEY}",
        "FINNHUB_API_KEY": "${FINNHUB_API_KEY}"
      },
      "_note": "Finance research MCP. Exposes finance_quote, finance_search, finance_sentiment. Requires: pip install mcp yfinance. ALPHA_VANTAGE_KEY is optional (sentiment degrades gracefully). FINNHUB_API_KEY is optional and improves fuzzy company-name search."
    }
  }
}
