{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {
        "DISABLE_THOUGHT_LOGGING": "false"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--output-dir",
        "/opt/openclaw/workspace/exports"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/opt/openclaw/workspace"
      ]
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ]
    },
    "lsp": {
      "command": "npx",
      "args": [
        "-y",
        "@akos/mcp-lsp-server"
      ],
      "env": {
        "LSP_LANGUAGES": "python,typescript"
      },
      "_note": "Phase 4: LSP code intelligence. Provides get_diagnostics, go_to_definition, find_references, get_type_signature."
    },
    "code-search": {
      "command": "npx",
      "args": [
        "-y",
        "@akos/mcp-code-search"
      ],
      "_note": "Phase 4: Semantic code search via ripgrep + tree-sitter. Provides search_code(query, scope)."
    }
  }
}
