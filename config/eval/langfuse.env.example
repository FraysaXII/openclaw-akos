# Langfuse AI Evaluation Platform — Configuration Template
# SOP Reference: 7.2
#
# Copy this file to langfuse.env and fill in real values.
# NEVER commit the actual langfuse.env file — it is excluded by .gitignore.

LANGFUSE_PUBLIC_KEY=your-public-key-here
LANGFUSE_SECRET_KEY=your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# Alternative platforms (uncomment one block):
#
# --- Maxim AI ---
# MAXIM_API_KEY=your-api-key-here
# MAXIM_HOST=https://api.getmaxim.ai
#
# --- LangSmith ---
# LANGCHAIN_API_KEY=your-api-key-here
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_PROJECT=openclaw-akos
