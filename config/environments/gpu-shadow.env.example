# ShadowPC OpenStack GPU Environment
# For GPU instances on Shadow's OpenStack infrastructure.
# Copy this to gpu-shadow.env and fill in your credentials.
#
# Usage:
#   1. Get your clouds.yaml from the Skyline dashboard OR set env vars below
#   2. Run `py scripts/gpu.py deploy-shadow`
#   3. Run `py scripts/switch-model.py gpu-shadow`

# ── OpenStack auth (Keystone v3) ──────────────────────────────────────
# Option A: Use a clouds.yaml file (set OS_CLOUD to the cloud name)
# OS_CLOUD=openstack

# Option B: Direct env vars
OS_AUTH_URL=https://auth.os1.frdun02.shadow.tech/v3
OS_PROJECT_ID=b87bea8ce7ec46be9b32d24a07e4d81f
OS_USERNAME=faycal-njoya-user
OS_PASSWORD=YOUR_PASSWORD_HERE
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
OS_REGION_NAME=FRDUN02

# ── vLLM endpoint URL (set after instance boots) ─────────────────────
VLLM_SHADOW_URL=http://localhost:8080/v1

# ── HuggingFace token for gated model downloads ──────────────────────
HF_TOKEN=YOUR_HF_TOKEN_HERE

# ── Inactive provider placeholders (gateway crash prevention) ────────
OLLAMA_API_KEY=not-configured
OLLAMA_GPU_URL=http://127.0.0.1:11434
OPENAI_API_KEY=not-configured
ANTHROPIC_API_KEY=not-configured
RUNPOD_API_KEY=not-configured
VLLM_RUNPOD_URL=http://localhost:8000/v1

# ── Langfuse observability (optional, no-op when unset) ──────────────
LANGFUSE_PUBLIC_KEY=your-public-key-here
LANGFUSE_SECRET_KEY=your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# Neo4j HLK graph (optional)
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
