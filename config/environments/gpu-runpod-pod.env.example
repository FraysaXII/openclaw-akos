# Dedicated RunPod Pod Environment
# For a persistent RunPod pod running vLLM (not serverless endpoints).
# Copy this to gpu-runpod-pod.env and fill in your pod URL.
#
# Usage:
#   1. Run `py scripts/setup-runpod-pod.py` to get vLLM launch commands
#   2. SSH into pod and run those commands
#   3. Set VLLM_RUNPOD_URL below to your pod's URL
#   4. Run `py scripts/switch-model.py gpu-runpod-pod`

# Your pod's vLLM endpoint (RunPod proxy or direct IP)
# Examples:
#   https://<pod-id>-8000.proxy.runpod.net/v1
#   http://149.36.1.31:8000/v1
VLLM_RUNPOD_URL=http://YOUR_POD_IP:8000/v1

# No live RunPod API key or endpoint ID is needed for dedicated pods during
# normal operation. A placeholder RUNPOD_API_KEY still exists below because
# openclaw.json.example now references `${RUNPOD_API_KEY}` for inventory-safe
# provider parsing across environments.

# ── Inactive provider placeholders (gateway crash prevention) ────────
# These must have values (even placeholder) so OpenCLAW's ${VAR} substitution
# doesn't crash. The gateway ignores providers with placeholder URLs.
OLLAMA_API_KEY=not-configured
OLLAMA_GPU_URL=http://localhost:11434
OPENAI_API_KEY=not-configured
ANTHROPIC_API_KEY=not-configured
RUNPOD_API_KEY=not-configured
VLLM_SHADOW_URL=http://localhost:8080/v1

# ── Langfuse observability (optional, no-op when unset) ──────────────
LANGFUSE_PUBLIC_KEY=your-public-key-here
LANGFUSE_SECRET_KEY=your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com
