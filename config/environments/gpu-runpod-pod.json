{
  "agents": {
    "defaults": {
      "model": {
        "primary": "vllm-runpod/deepseek-r1-70b",
        "fallbacks": [
          "anthropic/claude-sonnet-4",
          "ollama/deepseek-r1:14b"
        ]
      },
      "thinkingDefault": "medium",
      "verboseDefault": "on"
    }
  },
  "pod": {
    "mode": "dedicated",
    "healthEndpoint": "/health",
    "vllmPort": 8080,
    "gpuType": "NVIDIA A100-SXM4-80GB",
    "gpuCount": 2,
    "containerImage": "vllm/vllm-openai:v0.16.0",
    "volumeGb": 200,
    "envVars": {
      "TOKENIZER_MODE": "auto",
      "MAX_MODEL_LEN": "32768",
      "DTYPE": "float16",
      "GPU_MEMORY_UTILIZATION": "0.92",
      "KV_CACHE_DTYPE": "auto",
      "QUANTIZATION": "awq",
      "ENFORCE_EAGER": "true",
      "ENABLE_PREFIX_CACHING": "true",
      "ENABLE_CHUNKED_PREFILL": "true",
      "MAX_NUM_SEQS": "64",
      "MAX_NUM_BATCHED_TOKENS": "32768",
      "ENABLE_AUTO_TOOL_CHOICE": "true",
      "TOOL_CALL_PARSER": "deepseek_v3",
      "REASONING_PARSER": "deepseek_r1",
      "VLLM_ATTENTION_BACKEND": "TRITON_ATTN",
      "RAW_OPENAI_OUTPUT": "1",
      "OPENAI_SERVED_MODEL_NAME_OVERRIDE": "deepseek-r1-70b",
      "MAX_CONCURRENCY": "30",
      "DISABLE_LOG_STATS": "false"
    },
    "modelName": "casperhansen/deepseek-r1-distill-llama-70b-awq",
    "maxModelLen": 32768
  }
}
