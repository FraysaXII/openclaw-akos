# Production Cloud Environment
# Uses cloud API providers (OpenAI, Anthropic, etc.).
# Copy this file to prod-cloud.env and fill in your API keys.

OPENAI_API_KEY=YOUR_API_KEY_HERE
ANTHROPIC_API_KEY=YOUR_API_KEY_HERE

# ── Inactive provider placeholders (gateway crash prevention) ────────
OLLAMA_API_KEY=not-configured
OLLAMA_GPU_URL=http://127.0.0.1:11434
VLLM_RUNPOD_URL=http://localhost:8000/v1
RUNPOD_API_KEY=not-configured
VLLM_SHADOW_URL=http://localhost:8080/v1

# ── Langfuse observability (optional, no-op when unset) ──────────────
LANGFUSE_PUBLIC_KEY=your-public-key-here
LANGFUSE_SECRET_KEY=your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# Neo4j HLK graph (optional mirrored index; Neo4j Aura is the typical production target)
# NEO4J_URI: Aura console — prefer neo4j+s://… when system CAs validate the chain; use neo4j+ssc://…
# when Aura/your network requires relaxed server cert verify (then omit NEO4J_TRUST).
# NEO4J_TRUST: omit when using neo4j+ssc in the URI. Set to "all" only with neo4j+s to auto-rewrite to +ssc; see SECURITY.md §4a.
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
# NEO4J_TRUST=
