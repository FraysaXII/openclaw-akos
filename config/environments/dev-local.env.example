# Dev-Local Environment — SSOT for local Ollama development
# The OpenClaw gateway hard-fails on unresolved ${VAR} references at
# startup, so every env var referenced in openclaw.json.example must
# be defined here with at least a placeholder value.
#
# Usage:
#   - Bootstrap auto-seeds ~/.openclaw/.env from this file on first run.
#   - To switch environments later: py scripts/switch-model.py dev-local
#   - To use real cloud keys: copy this to dev-local.env and edit values.

# ── Active provider (Ollama local) ──────────────────────────────────
OLLAMA_API_KEY=ollama-local
OLLAMA_GPU_URL=http://127.0.0.1:11434

# ── Inactive provider placeholders ──────────────────────────────────
# These must exist so the gateway can parse openclaw.json without
# crashing.  Replace with real values when switching environments.
VLLM_RUNPOD_URL=http://localhost:8000/v1
OPENAI_API_KEY=not-configured
ANTHROPIC_API_KEY=not-configured
