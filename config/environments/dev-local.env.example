# Dev-Local Environment
# Local Ollama instance on the same machine.
# Copy this file to dev-local.env and adjust if needed.

OLLAMA_GPU_URL=http://127.0.0.1:11434/v1

# Placeholders for providers not used in dev-local.
# The OpenClaw gateway hard-fails on unresolved ${VAR} references,
# so every env var referenced in openclaw.json.example must be defined.
VLLM_RUNPOD_URL=http://localhost:8000/v1
OPENAI_API_KEY=not-configured
ANTHROPIC_API_KEY=not-configured
