# GPU RunPod Environment
# Remote vLLM endpoint on a RunPod serverless GPU instance.
# Copy this file to gpu-runpod.env and fill in your API key.

RUNPOD_API_KEY=YOUR_RUNPOD_API_KEY

# Auto-populated by `python scripts/switch-model.py gpu-runpod`
# via akos/runpod_provider.py ensure_endpoint().
# You can also set these manually from the RunPod dashboard.
VLLM_RUNPOD_URL=
RUNPOD_ENDPOINT_ID=

# Optional: remote Ollama on the same GPU instance
OLLAMA_GPU_URL=

# ── Inactive provider placeholders (gateway crash prevention) ────────
OLLAMA_API_KEY=not-configured
OPENAI_API_KEY=not-configured
ANTHROPIC_API_KEY=not-configured

# ── Langfuse observability (optional, no-op when unset) ──────────────
LANGFUSE_PUBLIC_KEY=your-public-key-here
LANGFUSE_SECRET_KEY=your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com
